# ─── Telegram ─────────────────────────────────────────────────────────────────
# The token you received from @BotFather when you created your bot.
# Example: 7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=7696772049:AAE8t6aaiICvbRvNRh857NXv6s4A0Kvjkv8

# The numeric chat ID of the Telegram group where EODs will be posted.
