# ─── Telegram ─────────────────────────────────────────────────────────────────
# The token you received from @BotFather when you created your bot.
# Example: 7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The numeric chat ID of the Telegram group where EODs will be posted.
# This is a negative number for group chats, e.g. -1001234567890
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Server ────────────────────────────────────────────────────────────────────
# Port the Express backend listens on (optional — defaults to 3001)
PORT=3690
