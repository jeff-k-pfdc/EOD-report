{
  "name": "eod-report",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently -k \"node server/server.js\" \"vite --port 5173\"",
    "build": "vite build",
    "electron": "npm run build && electron .",
    "electron-package": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "server": "node server/server.js",
    "create-shortcut": "powershell -ExecutionPolicy Bypass -File create-shortcut.ps1"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^5.4.10"
  },
  "build": {
    "appId": "com.eod.summary",
    "productName": "EOD Summary",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "server/**/*", "electron/**/*", "node_modules/**/*", ".env"],
    "win": { "target": "dir" }
  }
}
